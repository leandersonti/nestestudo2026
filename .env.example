# SIAP API (endpoints /usuarios/siap/siglas, /usuarios/siap/listagem, etc.)
SIAP_BASE_URL=https://siap-am.com/SIAP5/APISIAP_GMF.rule?sys=WWW
SIAP_API_TOKEN=your_siap_api_token_here

# Google Sheets API Configuration
# Option 1: Use API Key (for public sheets only)
GOOGLE_API_KEY=AIzaSyDv4l9eQPCn9-99FW6HgDI06qxEN4qv3Rk

# Option 2: Use Service Account credentials (for private sheets)
# Paste the entire JSON content as a single line
GOOGLE_CREDENTIALS={"type":"service_account","project_id":"..."}

# Opcional: mapeia nome exato da aba da planilha → nome do município (JSON objeto)
# Ex.: {"Lista Manaus":"Manaus","Aba Parintins":"Parintins"}
# Se omitido, municipio = título da aba.
SHEETS_MUNICIPIO_MAP=

# Database configurations (existing)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=password
DB_DATABASE=loja

